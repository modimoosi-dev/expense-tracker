{
  "appId": "com.expensetracker.bw",
  "appName": "Expense Tracker",
  "webDir": "public",
  "server": {
    "url": "https://expense-tracker-1-0mg2.onrender.com",
    "allowNavigation": ["expense-tracker-1-0mg2.onrender.com"]
  },
  "plugins": {
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": ["google.com"]
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#4f46e5",
      "overlaysWebView": false
    },
    "PushNotifications": {
      "presentationOptions": [
        "badge",
        "sound",
        "alert"
      ]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#4f46e5",
      "sound": "beep.wav"
    },
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": true,
      "backgroundColor": "#4f46e5",
      "androidSpinnerStyle": "large",
      "spinnerColor": "#ffffff",
      "showSpinner": true
    }
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
