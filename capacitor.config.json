{
  "appId": "com.expensetracker.bw",
  "appName": "Expense Tracker",
  "webDir": "public",
  "server": {
    "url": "https://expense-tracker-1-0mg2.onrender.com"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": [
        "badge",
        "sound",
        "alert"
      ]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#4f46e5",
      "sound": "beep.wav"
    },
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": false,
      "backgroundColor": "#4f46e5",
      "androidSpinnerStyle": "large",
      "spinnerColor": "#ffffff",
      "showSpinner": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  }
}
